          },
          "query": "// v.windowPeriod is a variable referring to the current optimized window period (currently: $interval)\nfrom(bucket: v.bucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"rabbitmq_queue\" and r[\"_field\"] == \"messages_publish\")\n  |> keep(columns: [\"_field\", \"_time\", \"_value\", \"queue\", \"vhost\"])\n  |> increase()\n  |> aggregateWindow(every: 30m, fn: max)\n  |> difference()\n  |> group(columns: [\"_time\", \"vhost\"])\n  |> sum()\n  |> group(columns: [\"_value\", \"_time\"], mode: \"except\")",
