      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "b6de785d-1681-4484-99de-fa00cc379495"
          },
          "query": "// v.windowPeriod is a variable referring to the current optimized window period (currently: $interval)\nfrom(bucket: v.bucket)\n  |> range(start: -60m)\n  |> filter(fn: (r) =>\n    r[\"_measurement\"] == \"rabbitmq_queue\"\n    and (r[\"_field\"] == \"messages\" or r[\"_field\"] == \"messages_ack\")\n  )\n  |> group(columns: [\"_field\", \"vhost\", \"queue\"])\n\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> difference(columns: [\"messages_ack\"])\n  |> max(column: \"messages_ack\")\n  |> min(column: \"messages\")\n\n  |> map(fn: (r) => ({ r with _value: (\n      if r.messages > 0 and r.messages_ack == 0 then\n       r.messages\n      else\n       0\n    )}))\n  |> drop(columns: [\"messages\", \"messages_ack\", \"_measurement\"])\n\n  |> group(columns: [\"_value\", \"_time\", \"vhost\"], mode: \"except\")\n  |> filter(fn: (r) => r._value > 0)\n",
          "refId": "A"
        }
      ],
      "title": "Non-empty queues with no messages consumed",
