          "query": "import \"date\"\n\n// prevent aligning of windows (stolen)\ninstances = ${instances:json}\nevery = 2h\noffset = duration(v: string(v: uint(v: now()) - uint(v:date.truncate(t: now(), unit: every))) + \"ns\")\n\n// v.windowPeriod is a variable referring to the current optimized window period (currently: $interval)\nfrom(bucket: v.bucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"orchesty\")\n  |> filter(fn: (r) => r[\"_field\"] == \"procs_failed\")\n  |> filter(fn: (r) => contains(value: r[\"instance\"], set: instances))\n  |> group(columns: [\"url\"])\n  |> sort(columns: [\"_time\"])\n  |> increase()\n  |> aggregateWindow(every: every, offset: offset, fn: max)\n  |> difference()\n  |> group(columns: [\"_time\"])\n  |> sum()\n  |> group()\n",
          "refId": "A"
        }
      ],
      "type": "stat"
