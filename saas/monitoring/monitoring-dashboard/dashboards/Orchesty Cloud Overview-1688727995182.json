          "query": "instances = ${instances:json}\n\n// v.bucket, v.timeRangeStart, and v.timeRange stop are all variables supported by the flux plugin and influxdb\nfrom(bucket: v.bucket)\n  |> range(start: -10m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"logging.googleapis.com/user\" and r[\"_field\"] == \"no-rabbit-conn-messages\")\n  |> filter(fn: (r) => contains(value: r[\"instance\"], set: instances))\n  |> group(columns: [\"namespace_name\", \"orchesty_service\", \"_field\"])\n  |> max()\n",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": ".*namespace_name=\\\"(.*?)\\\".*orchesty_service=\\\"(.*?)\\\".*",
