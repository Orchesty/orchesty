          "query": "import \"date\"\n\n// prevent aligning of windows (stolen)\nevery = 2h\noffset = duration(v: string(v: uint(v: now()) - uint(v:date.truncate(t: now(), unit: every))) + \"ns\")\n\n// v.windowPeriod is a variable referring to the current optimized window period (currently: $interval)\nfrom(bucket: v.bucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"orchesty\" and r[\"url\"] == \"${instances}\")\n  |> filter(fn: (r) => r[\"_field\"] == \"succsessful\" or r[\"_field\"] == \"procs_failed\")\n  |> group(columns: [\"url\"])\n  |> aggregateWindow(every: every, offset: offset, fn: max, )\n  |> difference(nonNegative: true)\n  |> yield()\n",
