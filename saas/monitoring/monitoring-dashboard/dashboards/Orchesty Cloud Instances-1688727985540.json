          "query": "import \"experimental/aggregate\"\n\n// v.windowPeriod is a variable referring to the current optimized window period (currently: $interval)\nfrom(bucket: v.bucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"orchesty\" and r[\"url\"] == \"${instances}\")\n  |> filter(fn: (r) => r[\"_field\"] == \"procs_succeeded\")\n  |> group(columns: [\"url\"])\n  |> sort(columns: [\"_time\"])\n  |> increase()\n  |> aggregateWindow(every: v.windowPeriod, fn: last)\n  |> difference()\n  |> yield()\n",
