DEV_UID={DEV_UID}
DEV_GID={DEV_GID}

# App
APP_DEBUG=true
APP_PORT=8080

# MongoDB
MONGODB_DSN=mongodb://mongodb:27017/admin
MONGODB_HOSTNAME=mongodb

# RabbitMQ
RABBIT_HOSTNAME=rabbitmq
RABBIT_ADMIN_USER=guest
RABBIT_ADMIN_PASS=guest

# Kubernetes
K8S_CLUSTER_CONFIG=

# Helm
HELM_ROOT_DIR_FOR_FILES=/tmp/helm
HELM_ORCHESTY_VERSION=~2.1.15
HELM_BRIDGEPOOL_KEY=bridgepool
