#!/usr/bin/env node

// TODO get topology from config microservice
const topology = require('../src/example/dev-topology');
const Pipes = require('../src/pipes');

const pipes = Pipes(topology);

const yargs = require('yargs')
  .usage('Usage: $0 start <services|node> [options]')
  .command('start <services|node>', 'Starts services or node')
  .option('id', {
    describe: 'Node ID to start',
    type: 'string'
  })
  .demandCommand(1, 'You need to specify command.')
  .help()
  .argv;

switch (yargs.services) {
  case 'services':
    pipes.startCounter();
    pipes.startProbe();
    break;
  case 'node':
    console.log(`Starting node '${yargs.id}'`);
    pipes.startNode(yargs.id);
    break;
  default:
}
