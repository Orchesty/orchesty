<!doctype html>
<html lang="en">
    <head>
        <title>PIPES - DOCS </title>
        <meta name="keywords" content="">
        <meta name="description" content=""/>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

        <!-- Compiled and minified CSS -->
        <link rel="stylesheet"
              href="https://fonts.googleapis.com/css?family=Roboto:100,300,400,500,700,900|Material+Icons"
              data-packer="exclude">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css"
              data-packer="exclude">

        <link rel="stylesheet" href="/assets/css/screen.css">
        <link rel="stylesheet" href="/assets/css/layout.css">
        <link rel="stylesheet" href="/assets/css/code/main.css">
        <link rel="stylesheet" href="/assets/css/code/theme/dracula.css">

        <!-- Compiled and minified JavaScript -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    </head>
    <body>
        <main>
            <!-- TOP NAV -->
            <div class="navbar-fixed">
                <nav>
                    <div class="container nav-wrapper">
                        <a href="#!" class="brand-logo">LOGO</a>
                        <ul class="right hide-on-med-and-down">
                            <li><a href="/">Docs</a></li>
                            <li><a href="/docs/stack/download/download">Download</a></li>
                        </ul>
                    </div>
                </nav>
            </div>

            <!-- COLAPS NAV -->
            <ul class="collapsible hide-on-large-only">
                <li>
                    <div class="collapsible-header"><i class="material-icons">filter_drama</i>Docs</div>
                    <div class="collapsible-body"><span>Menu</span></div>
                </li>
                <li>
                    <div class="collapsible-header"><i class="material-icons">place</i>Download</div>
                    <div class="collapsible-body"><span>Menu</span></div>
                </li>
            </ul>


            <div class="container">
                <div class="row">
                    <div class="col l2 hide-on-med-and-down table-of-contents"
                         style="position: sticky; overflow: hidden; top: 50px;">
                        <ul class="left section">
                            <h4>MENU</h4>
                            <li class="divider"></li>
                            <!--                    Generating left menu name is set in YAML head in each .MD / to set value of menu change YAML-->
                            {{#each collections }}
                                {{#each (sortMenu this)}}
                                    <li>
                                        <a href="/{{this.path}}" class="leftNav level_{{this.level}}">{{this.name}}</a>
                                    </li>
                                    {{#each this.children}}
                                        <li>
                                            <a href="/{{this.path}}"
                                               class="leftNav level_{{this.level}}">{{this.name}}</a>
                                        </li>
                                    {{/each}}
                                {{/each}}
                            {{/each}}
                        </ul>
                    </div>


                    <!--    Content-->
                    <div class="container col s12 m12 l8">
                        <div class="row">
                            {{{contents}}}
                        </div>
                    </div>


                    <!--    Right Scrollspy   -->
                    <div class="col l2 hide-on-med-and-down"
                         style="position: sticky; overflow: hidden; top: 50px; text-align: left">
                        <ul class="right section table-of-contents">
                            <h4>CONTENTS</h4>
                            <li class="divider"></li>
                            <!--    Generating list of headings from object " " -->
                            {{#if headings}}
                                <!--    Write "log this" into two curly brackets to "debug" the handelbars objects-->
                                {{#each headings}}
                                    <li><a href="#{{id}}">{{text}}</a></li>
                                {{/each}}
                            {{/if}}
                        </ul>
                    </div>
                </div>
            </div>
        </main>

        <!--FOOTER-->
        <footer class="page-footer">
            <div class="row">
                <div class="container">
                    <div class="col l6 s12">
                        <h5 class="white-text">Hanaboso footer</h5>
                        <p class="grey-text text-lighten-4">You can use rows and columns here to organize your footer
                            content.</p>
                    </div>
                    <div class="col l4 offset-l2 s12 center-align">
                        <h5 class="white-text">Links</h5>
                        <ul>
                            <li><a class="grey-text text-lighten-3" href="#!">Link 1</a></li>
                            <li><a class="grey-text text-lighten-3" href="#!">Link 2</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </footer>
        <script src="/assets/js/codeBlock.js"></script>
        <script src="/assets/js/main.js"></script>
    </body>
</html>