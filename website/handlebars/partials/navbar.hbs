<div id="navbar-container">
	<div id="primary-navbar-fixed" class="navbar-container d-flex p-fixed fd-column">
		<div class="container d-flex jc-space-between ai-center fg-1">
			<a href="#" class="d-flex">
				<img class="logo" src="/img/logo_1.png" alt="pipes">
			</a>


			<div class="hide-sm-down">
				{{>main-menu}}
			</div>

			<div class="hide-md-up">
				<button id="main-menu-btn">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
						<path
							d="M16 132h416c8.837 0 16-7.163 16-16V76c0-8.837-7.163-16-16-16H16C7.163 60 0 67.163 0 76v40c0 8.837 7.163 16 16 16zm0 160h416c8.837 0 16-7.163 16-16v-40c0-8.837-7.163-16-16-16H16c-8.837 0-16 7.163-16 16v40c0 8.837 7.163 16 16 16zm0 160h416c8.837 0 16-7.163 16-16v-40c0-8.837-7.163-16-16-16H16c-8.837 0-16 7.163-16 16v40c0 8.837 7.163 16 16 16z" />
					</svg>
				</button>
			</div>
		</div>
	</div>

	<div id="fixed-main-menu-container" class="hide-md-up p-fixed">
		<div class="container">
			{{>main-menu}}
		</div>
	</div>

	<div id="secondary-navbar-fixed" class="hide-md-up p-fixed d-flex">
		<div class="container d-flex ai-center jc-space-between">
			<div class="main-container">
				<div class="current">
                    {{name}}
				</div>
				<div class="search">
					{{>search}}
				</div>
			</div>

			<div class="btn-container">
				<button id="secondary-menu-btn">
					<svg class="down" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
						<path
							d="M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z" />
					</svg>
					<svg class="up" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
						<path
							d="M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z" />
					</svg>
				</button>
			</div>
		</div>
	</div>

	<div id="fixed-sidebar-nav-container" class="hide-md-up p-fixed">
		<div class="container pb-3">
			{{>left-sidebar-nav}}
		</div>
	</div>
</div>