{
  "name": "@hanabooso/pipes",
  "version": "1.0.0",
  "license": "Elastic-2.0",
  "scripts": {
    "serve": "vite preview",
    "build": "vite build",
    "start": "vite",
    "test:unit": "vitest run",
    "lint": "eslint '**/*.{js,ts,vue}'",
    "lint:fix": "eslint --fix '**/*.{js,ts,vue}'",
    "lint:styles": "stylelint '**/*.{css,scss,vue}'",
    "lint:styles:fix": "stylelint --fix '**/*.{css,scss,vue}'",
    "format:check": "prettier --check '**/*.{js,ts,vue,json,yml,mjs,css,scss,md}'",
    "format": "prettier --write '**/*.{js,ts,vue,json,yml,mjs,css,scss,md}'",
    "validate": "run-p -l lint lint:styles format:check test:unit",
    "vue-i18n-extract": "node ./src/localization/transform.mjs && vue-i18n-extract report --vueFiles './src/**/*.?(js|vue)' --languageFiles './src/localization/generated/*.json' && rm -rf './src/localization/generated/'"
  },
  "packageManager": "pnpm@9.1.4",
  "dependencies": {
    "@casl/ability": "^6.7.3",
    "@casl/vue": "^1.2.3",
    "@mdi/font": "^7.4.47",
    "axios": "^1.12.2",
    "bpmn-js": "^9.4.1",
    "bpmn-js-properties-panel": "^0.46.0",
    "camunda-bpmn-moddle": "^6.1.2",
    "chart.js": "^4.5.0",
    "core-js": "^3.45.1",
    "cron-parser": "^5.4.0",
    "diagram-js": "^8.9.0",
    "inherits": "^2.0.4",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "pretty-ms": "^9.3.0",
    "regenerator-runtime": "^0.14.1",
    "tiny-svg": "^4.1.3",
    "validator": "^13.15.15",
    "vee-validate": "^3.4.15",
    "vue": "^2.7.16",
    "vue-cli-plugin-vuetify": "^2.5.8",
    "vue-i18n": "^8.28.2",
    "vue-json-pretty": "^1.9.5",
    "vue-router": "^3.6.5",
    "vuetify": "^2.7.2",
    "vuetify-loader": "^1.9.2",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.4",
