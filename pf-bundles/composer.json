{
    "name": "orchesty/backend",
    "description": "Orchesty backend",
    "license": "Elastic-2.0",
    "version": "3.3.4",
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-mongodb": "*",
        "doctrine/mongodb-odm-bundle": "^5.6",
        "doctrine/orm": "^3.6",
        "hanaboso/acl-bundle": "^1.11",
        "hanaboso/email-service-bundle": "^1.7",
        "hanaboso/mongo-data-grid": "^2.0",
        "hanaboso/rabbit-mq-bundle": "^1.10",
        "hanaboso/rest-bundle": "^1.6",
        "hanaboso/user-bundle": "^1.12",
        "symfony/security-bundle": "^8.0",
        "symfony/serializer": "^8.0"
    },
    "require-dev": {
        "hanaboso/php-check-utils": "^2.0",
        "predis/predis": "^3.3"
    },
    "replace": {
        "ralouphie/getallheaders": "*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-intl-grapheme": "*",
        "symfony/polyfill-intl-icu": "*",
        "symfony/polyfill-intl-idn": "*",
        "symfony/polyfill-intl-normalizer": "*",
        "symfony/polyfill-mbstring": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "autoload": {
        "psr-4": {
            "Hanaboso\\PipesFramework\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PipesFrameworkTests\\": "tests",
            "UserBundleTests\\": "vendor/hanaboso/user-bundle/tests"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true
        }
    }
}
