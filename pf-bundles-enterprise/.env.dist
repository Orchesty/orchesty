DEV_UID={DEV_UID}
DEV_GID={DEV_GID}
DEV_IP=127.0.0.1
TUNNEL_PROXY_HOST=

# Trace docs_search MCP tool — public Orchesty docs site (Nuxt). Leave
# empty to hide the tool from the manifest entirely (recommended for
# on-prem deployments without internet access). DOCS_SEARCH_TOKEN must
# match the Nuxt-side NUXT_TRACE_SEARCH_TOKEN.
DOCS_SEARCH_URL=
DOCS_SEARCH_TOKEN=
