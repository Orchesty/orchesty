{
    "name": "orchesty/applinth",
    "description": "Orchesty - applinth - Backend",
    "license": "Elastic-2.0",
    "version": "1.0.1",
    "require": {
        "doctrine/annotations": "^1.13",
        "orchesty/backend": "^2.1",
        "web-token/jwt-bundle": "^3.1",
        "web-token/jwt-encryption": "^3.1",
        "web-token/jwt-encryption-algorithm-aesgcm": "^3.1",
        "web-token/jwt-encryption-algorithm-ecdh-es": "^3.1",
        "web-token/jwt-encryption-algorithm-rsa": "^3.1",
        "web-token/jwt-signature-algorithm-eddsa": "^3.1"
    },
    "require-dev": {
        "hanaboso/php-check-utils": "^1.3"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../pf-bundles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../pipes-php-sdk",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Hanaboso\\Applinth\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApplinthTests\\": "tests",
            "UserBundleTests\\": "vendor/hanaboso/user-bundle/tests"
        }
    }
}
