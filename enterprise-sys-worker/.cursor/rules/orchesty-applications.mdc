# Writing Applications

## OAuth2 Application Template (Authorization Code)

Use when the target API requires **interactive user login** (browser redirect flow). The SDK handles token refresh automatically.

```typescript
import AOAuth2Application from '@orchesty/nodejs-sdk/dist/lib/Authorization/Type/OAuth2/AOAuth2Application';
import RequestDto from '@orchesty/nodejs-sdk/dist/lib/Transport/Curl/RequestDto';
import { ApplicationInstall } from '@orchesty/nodejs-sdk/dist/lib/Application/Database/ApplicationInstall';
import { CommonHeaders, JSON_TYPE } from '@orchesty/nodejs-sdk/dist/lib/Utils/Headers';
import AProcessDto from '@orchesty/nodejs-sdk/dist/lib/Utils/AProcessDto';
import Form from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/Form';
import Field from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/Field';
import FieldType from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/FieldType';
import FormStack from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/FormStack';
import { CLIENT_ID, CLIENT_SECRET } from '@orchesty/nodejs-sdk/dist/lib/Authorization/Type/OAuth2/IOAuth2Application';
import CoreFormsEnum, { getFormName } from '@orchesty/nodejs-sdk/dist/lib/Application/Base/CoreFormsEnum';

export const BASE_URL = 'https://api.example.com/v1';

export default class MyOAuth2App extends AOAuth2Application {
    public getName(): string { return 'my-app'; }
    public getPublicName(): string { return 'My App'; }
    public getDescription(): string { return 'My application description'; }

    public getAuthUrl(): string { return 'https://auth.example.com/authorize'; }
    public getTokenUrl(): string { return 'https://auth.example.com/token'; }
    public getScopes(_appInstall: ApplicationInstall): string[] { return ['scope1']; }

    public getRequestDto(
        dto: AProcessDto, appInstall: ApplicationInstall, method: string, url?: string, data?: unknown,
    ): RequestDto {
        return new RequestDto(url ?? BASE_URL, method, dto, data, {
            [CommonHeaders.CONTENT_TYPE]: JSON_TYPE,
            [CommonHeaders.ACCEPT]: JSON_TYPE,
            [CommonHeaders.AUTHORIZATION]: `Bearer ${this.getAccessToken(appInstall)}`,
        });
    }

    public getFormStack(): FormStack {
        const form = new Form(CoreFormsEnum.AUTHORIZATION_FORM, getFormName(CoreFormsEnum.AUTHORIZATION_FORM))
            .addField(new Field(FieldType.TEXT, CLIENT_ID, 'Client Id', null, true))
            .addField(new Field(FieldType.TEXT, CLIENT_SECRET, 'Client Secret', null, true));
        return new FormStack().addForm(form);
    }

    public isAuthorized(appInstall: ApplicationInstall): boolean {
        const form = appInstall.getSettings()[CoreFormsEnum.AUTHORIZATION_FORM];
        return super.isAuthorized(appInstall) && !!form?.[CLIENT_ID] && !!form?.[CLIENT_SECRET];
    }
}
```

## Client Credentials Application Template

Use for **server-to-server** integrations where no interactive browser login is needed. Extend `ABasicApplication` and handle the token exchange manually via `fetch`, with an in-memory cache.

```typescript
import { ABasicApplication } from '@orchesty/nodejs-sdk/dist/lib/Authorization/Type/Basic/ABasicApplication';
import { ApplicationInstall } from '@orchesty/nodejs-sdk/dist/lib/Application/Database/ApplicationInstall';
import RequestDto from '@orchesty/nodejs-sdk/dist/lib/Transport/Curl/RequestDto';
import { CommonHeaders, JSON_TYPE } from '@orchesty/nodejs-sdk/dist/lib/Utils/Headers';
import { HttpMethods } from '@orchesty/nodejs-sdk/dist/lib/Transport/HttpMethods';
import AProcessDto from '@orchesty/nodejs-sdk/dist/lib/Utils/AProcessDto';
import CoreFormsEnum, { getFormName } from '@orchesty/nodejs-sdk/dist/lib/Application/Base/CoreFormsEnum';
import Form from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/Form';
import Field from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/Field';
import FieldType from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/FieldType';
import FormStack from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/FormStack';

const CLIENT_ID = 'client_id';
const CLIENT_SECRET = 'client_secret';
const TOKEN_URL = 'https://identity.example.com/connect/token';
const tokenCache = new Map<string, { accessToken: string; expiresAt: number }>();

export default class MyClientCredentialsApp extends ABasicApplication {
    public getName(): string { return 'my-app'; }
    public getPublicName(): string { return 'My App'; }
    public getDescription(): string { return 'My app (Client Credentials)'; }

    public getFormStack(): FormStack {
        const form = new Form(CoreFormsEnum.AUTHORIZATION_FORM, getFormName(CoreFormsEnum.AUTHORIZATION_FORM))
            .addField(new Field(FieldType.TEXT, CLIENT_ID, 'Client Id', null, true))
            .addField(new Field(FieldType.PASSWORD, CLIENT_SECRET, 'Client Secret', null, true));
        return new FormStack().addForm(form);
    }

    public isAuthorized(appInstall: ApplicationInstall): boolean {
        const form = appInstall.getSettings()?.[CoreFormsEnum.AUTHORIZATION_FORM];
        return !!form?.[CLIENT_ID] && !!form?.[CLIENT_SECRET];
    }

    public async getRequestDto(
        dto: AProcessDto, appInstall: ApplicationInstall, method: string, url?: string, data?: unknown,
    ): Promise<RequestDto> {
        const token = await this.getAccessToken(appInstall);
        return new RequestDto(url ?? '', method as HttpMethods, dto, data, {
            [CommonHeaders.CONTENT_TYPE]: JSON_TYPE,
            [CommonHeaders.ACCEPT]: JSON_TYPE,
            [CommonHeaders.AUTHORIZATION]: `Bearer ${token}`,
        });
    }

    private async getAccessToken(appInstall: ApplicationInstall): Promise<string> {
        const settings = appInstall.getSettings()?.[CoreFormsEnum.AUTHORIZATION_FORM];
        const clientId = settings?.[CLIENT_ID] as string;
        const clientSecret = settings?.[CLIENT_SECRET] as string;
        const cached = tokenCache.get(clientId);
        if (cached && cached.expiresAt > Date.now() + 60_000) return cached.accessToken;

        const resp = await fetch(TOKEN_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({
                grant_type: 'client_credentials',
                client_id: clientId,
                client_secret: clientSecret,
                scope: 'api',
            }).toString(),
        });
        if (!resp.ok) throw new Error(`Token request failed [${resp.status}]: ${await resp.text()}`);

        const { access_token, expires_in } = (await resp.json()) as { access_token: string; expires_in: number };
        tokenCache.set(clientId, { accessToken: access_token, expiresAt: Date.now() + expires_in * 1_000 });
        return access_token;
    }
}
```

## Basic Auth Application Template

Use when the target API requires a **username + password** (HTTP Basic Auth).

```typescript
import { ABasicApplication } from '@orchesty/nodejs-sdk/dist/lib/Authorization/Type/Basic/ABasicApplication';
import { ApplicationInstall } from '@orchesty/nodejs-sdk/dist/lib/Application/Database/ApplicationInstall';
import RequestDto from '@orchesty/nodejs-sdk/dist/lib/Transport/Curl/RequestDto';
import { CommonHeaders, JSON_TYPE } from '@orchesty/nodejs-sdk/dist/lib/Utils/Headers';
import { HttpMethods } from '@orchesty/nodejs-sdk/dist/lib/Transport/HttpMethods';
import AProcessDto from '@orchesty/nodejs-sdk/dist/lib/Utils/AProcessDto';
import CoreFormsEnum, { getFormName } from '@orchesty/nodejs-sdk/dist/lib/Application/Base/CoreFormsEnum';
import Form from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/Form';
import Field from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/Field';
import FieldType from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/FieldType';
import FormStack from '@orchesty/nodejs-sdk/dist/lib/Application/Model/Form/FormStack';

const USERNAME = 'username';
const PASSWORD = 'password';
const BASE_URL_KEY = 'base_url';

export default class MyBasicAuthApp extends ABasicApplication {
    public getName(): string { return 'my-app'; }
    public getPublicName(): string { return 'My App'; }
    public getDescription(): string { return 'My app (Basic Auth)'; }

    public getFormStack(): FormStack {
        const form = new Form(CoreFormsEnum.AUTHORIZATION_FORM, getFormName(CoreFormsEnum.AUTHORIZATION_FORM))
            .addField(new Field(FieldType.TEXT, USERNAME, 'Username', null, true))
            .addField(new Field(FieldType.PASSWORD, PASSWORD, 'Password', null, true))
            .addField(new Field(FieldType.TEXT, BASE_URL_KEY, 'Base URL', null, true));
        return new FormStack().addForm(form);
    }

    public isAuthorized(appInstall: ApplicationInstall): boolean {
        const form = appInstall.getSettings()?.[CoreFormsEnum.AUTHORIZATION_FORM];
        return !!form?.[USERNAME] && !!form?.[PASSWORD];
    }

    public getRequestDto(
        dto: AProcessDto, appInstall: ApplicationInstall, method: string, url?: string, data?: unknown,
    ): RequestDto {
        const settings = appInstall.getSettings()?.[CoreFormsEnum.AUTHORIZATION_FORM];
        const username = settings?.[USERNAME] as string;
        const password = settings?.[PASSWORD] as string;
        const baseUrl = settings?.[BASE_URL_KEY] as string;
        const token = Buffer.from(`${username}:${password}`).toString('base64');

        return new RequestDto(url ?? baseUrl, method as HttpMethods, dto, data, {
            [CommonHeaders.CONTENT_TYPE]: JSON_TYPE,
            [CommonHeaders.ACCEPT]: JSON_TYPE,
            [CommonHeaders.AUTHORIZATION]: `Basic ${token}`,
        });
    }
}
```

## Custom Settings Forms

Applications can expose **custom settings** beyond the authorization form. Use a separate form for service-specific configuration (e.g. organization ID, environment URL):

```typescript
const CUSTOM_FORM = 'custom_settings';
const ORG_ID = 'organization_id';

public getFormStack(): FormStack {
    const authForm = new Form(CoreFormsEnum.AUTHORIZATION_FORM, getFormName(CoreFormsEnum.AUTHORIZATION_FORM))
        .addField(new Field(FieldType.TEXT, CLIENT_ID, 'Client Id', null, true));

    const customForm = new Form(CUSTOM_FORM, 'Custom Settings')
        .addField(new Field(FieldType.TEXT, ORG_ID, 'Organization ID', null, true));

    return new FormStack().addForm(authForm).addForm(customForm);
}

// Access custom settings in connectors via:
// const orgId = appInstall.getSettings()[CUSTOM_FORM]?.[ORG_ID] as string;
```

## Key Rules

- **Application names** use kebab-case: `my-service`, `erp-system`.
- `getRequestDto()` must return a fully authenticated `RequestDto` — connectors rely on this.
- If `getRequestDto()` doesn't set `Content-Type: application/json` by default, connectors sending JSON must set it explicitly. Forgetting this causes `400 Bad Request` errors.
- For OAuth2 Authorization Code flow, use `AOAuth2Application` — the SDK handles token refresh automatically.
- For Client Credentials flow, extend `ABasicApplication` and manage tokens manually with an in-memory cache keyed by `clientId`.
- For Basic Auth, extend `ABasicApplication` and compute the `Authorization: Basic <base64>` header in `getRequestDto()`.
- **`isAuthorized()` must only check auth credentials**, never custom settings. The Orchesty UI calls `isAuthorized()` to decide whether to enable the OAuth authorize button. If it also checks fields from custom settings forms (e.g. API keys, account IDs), the user cannot complete authorization until all forms are filled — but custom settings often depend on a working auth first. Validate custom settings at runtime in connectors/batches via `checkParams()` instead.
- **Custom settings fields can be `required: true`** — each form in the `FormStack` should be validated and submitted independently by the UI. If the UI incorrectly validates all forms together, that is a UI bug, not a worker-side issue.
- **Use `FieldType.TEXT` for API keys**, not `FieldType.PASSWORD`. Password fields mask the value, making it hard for users to verify correctness. API keys are not passwords — use a plain text input so the value is visible.

## OAuth2 Constructor — OAuth2Provider Required

`AOAuth2Application` requires an `OAuth2Provider` instance in its constructor. This provider is created automatically by `initiateContainer()` and stored in the DI container. Retrieve it and pass it when instantiating any OAuth2 application:

```typescript
import { OAuth2Provider } from '@orchesty/nodejs-sdk/dist/lib/Authorization/Provider/OAuth2/OAuth2Provider';

initiateContainer();
const oauth2Provider = container.get(OAuth2Provider);
const app = new MyOAuth2App(oauth2Provider);
container.setApplication(app);
```

This applies to all classes extending `AOAuth2Application`, including `AGoogle` from `@orchesty/connector-google-common`. `ABasicApplication` subclasses do **not** need any constructor argument.
