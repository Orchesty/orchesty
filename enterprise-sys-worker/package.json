    "@orchesty/connector-slack": "^1.0.1",
    "@orchesty/connector-smtp": "^1.0.1",
    "@orchesty/nodejs-sdk": "^5.0.3",
    "dotenv": "^16.6.1"
  },
  "pnpm": {
    "overrides": {
      "@orchesty/nodejs-sdk": "^5.0.3"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@hanaboso/eslint-plugin": "^1.2.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
