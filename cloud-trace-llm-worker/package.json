{
  "name": "cloud-trace-llm-worker",
  "description": "Orchesty cloud-relay worker hosting the default Trace LLM applications (OpenAI today, Anthropic/Gemini in the future). Registered with the system instance only.",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "main": "server.js",
  "scripts": {
    "test": "jest --coverage --detectOpenHandles --passWithNoTests",
    "lint": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "start": "nodemon src/server.ts",
    "build": "rm -rf dist && tsc -p tsconfig.prod.json && copyfiles -u 1 \"src/**/*.html\" \"src/**/*.md\" dist/src/"
  },
  "keywords": [],
  "dependencies": {
    "@orchesty/connector-open-ai": "^2.0.0",
    "@orchesty/nodejs-sdk": "^5.0.9",
    "dotenv": "^17.4.2"
  },
  "pnpm": {
    "overrides": {
       "eslint": "$eslint"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@hanaboso/eslint-plugin": "^1.2.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
