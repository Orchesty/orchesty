    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^10.0.0",
    "babel-loader": "^8.4.1",
    "cssnano": "^5.1.15",
    "eslint": "^7.32.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^8.7.1",
    "graphql": "^16.10.0",
    "npm-run-all": "^4.1.5",
