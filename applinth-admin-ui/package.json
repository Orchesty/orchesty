{
  "name": "applinth-admin-ui",
  "version": "0.1.0",
  "license": "Elastic-2.0",
  "scripts": {
    "serve": "vue-cli-service serve",
    "start": "npm run serve",
    "build": "vue-cli-service build --modern",
    "dev": "run-p -l serve api:mock api:ui",
    "storybook": "vue-cli-service storybook:serve -p 6006 -s ./public",
    "storybook:build": "vue-cli-service storybook:build",
    "api:generate": "rimraf src/api/generated/; openapi-generator-cli generate --skip-validate-spec -i ../saas/console-api/openapi.yaml -g typescript-fetch -o src/api/generated/ --additional-properties=supportsES6=true",
    "api:mock": "prism mock --dynamic --host 0.0.0.0 --port 4010 ../saas/console-api/openapi.yaml",
    "api:ui": "npx swagger-ui-cli --port 4011 ../saas/console-api/openapi.yaml",
    "download:apps-metadata": "node src/script/downloadAppsMetadata.ts",
    "lint": "eslint '**/*.{js,ts,vue}'",
    "lint:fix": "eslint --fix '**/*.{js,ts,vue}'",
    "lint:styles": "stylelint '**/*.{css,scss,vue}'",
    "lint:styles:fix": "stylelint --fix '**/*.{css,scss,vue}'",
    "format:check": "prettier --check '**/*.{js,ts,vue,json,yml,mjs,css,scss,md}'",
    "format": "prettier --write '**/*.{js,ts,vue,json,yml,mjs,css,scss,md}'",
    "test": "",
    "validate": "run-p -l lint lint:styles format:check test"
  },
  "packageManager": "pnpm@7.21.0",
