    "@types/lodash.clonedeep": "^4.5.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/luxon": "^2.4.0",
    "axios": "^1.8.4",
    "chart.js": "^3.9.1",
    "core-js": "^3.41.0",
    "diacritics": "^1.3.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "firebase": "^9.23.0",
    "gql-tag": "^1.0.1",
    "lodash.clonedeep": "^4.5.0",
    "lodash.merge": "^4.6.2",
    "luxon": "^2.5.2",
    "material-design-icons-iconfont": "^6.7.0",
    "regenerator-runtime": "^0.13.11",
    "vee-validate": "^3.4.15",
    "vue": "^2.7.16",
    "vue-class-component": "^7.2.6",
    "vue-i18n": "^8.28.2",
