{
  "name": "hanaboso/demo",
  "license": "proprietary",
  "type": "project",
  "autoload": {
    "psr-4": {
      "Demo\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "hanaboso/pipes-framework": "^1.0",
    "nelmio/cors-bundle": "^1.5",
    "php": ">=7.1",
    "react/child-process": "^0.5",
    "symfony/lts": "^4@dev",
    "symfony/serializer": "^4.0"
  },
  "require-dev": {
    "hanaboso/php-check-utils": "^1.0",
    "hanaboso/email-service-bundle": "^1.0",
    "phpunit/phpunit": "^7.0",
    "symfony/debug-bundle": "^4.0",
    "symfony/web-profiler-bundle": "^4.0",
    "symfony/browser-kit": "^4.0"
  },
  "config": {
    "sort-packages": true
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../../pf-bundles",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "git",
      "url": "git@gitlab.hanaboso.net:hanaboso/email-service-bundle.git"
    }

  ]
}
