{
    "name": "hanaboso/demo",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^7.4",
        "ext-json": "*",
        "hanaboso/app-store": "^1.5",
        "hanaboso/commons-bundle": "^2.2",
        "hanaboso/email-service-bundle": "^1.1",
        "hanaboso/pipes-connectors": "^1.5",
        "hanaboso/pipes-php-sdk": "^1.5",
        "hanaboso/rabbit-mq-bundle": "^1.4",
        "hanaboso/rest-bundle": "^1.0",
        "kucharovic/czech-holidays": "^1.0",
        "ratchet/pawl": "^0.3"
    },
    "require-dev": {
        "hanaboso/php-check-utils": "^1.1",
        "symfony/debug-bundle": "^5.1",
        "symfony/security-bundle": "^5.1",
        "symfony/serializer": "^5.1"
    },
    "autoload": {
        "psr-4": {
            "Demo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DemoTests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../../pipes-php-sdk",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../../app-store",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../../pipes-connectors",
            "options": {
                "symlink": true
            }
        }
    ]
}
