    "hanaboso/pipes-php-sdk": "^1.0",
    "hanaboso/rabbit-mq-bundle": "^1.1",
    "hanaboso/user-bundle": "^1.0",
    "nelmio/cors-bundle": "^1.5",
    "ratchet/pawl": "^0.3",
    "react/child-process": "^0.5"
  },
  "require-dev": {
    "hanaboso/php-check-utils": "^1.0"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../../pf-bundles",
      "options": {
        "symlink": true
