{
    "name": "orchesty/php-demo",
    "license": "proprietary",
    "type": "project",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "azuyalabs/yasumi": "^2.5",
        "hanaboso/commons-bundle": "^2.8",
        "hanaboso/email-service-bundle": "^1.2",
        "hanaboso/rest-bundle": "^1.1",
        "orchesty/php-connectors": "^3.0",
        "orchesty/php-sdk": "^3.0",
        "symfony/security-bundle": "^6.2"
    },
    "require-dev": {
        "hanaboso/php-check-utils": "^1.5",
        "symfony/debug-bundle": "^6.2",
        "symfony/serializer": "^6.2"
    },
    "replace": {
        "ralouphie/getallheaders": "*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-intl-grapheme": "*",
        "symfony/polyfill-intl-icu": "*",
        "symfony/polyfill-intl-idn": "*",
        "symfony/polyfill-intl-normalizer": "*",
        "symfony/polyfill-mbstring": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../../pipes-php-sdk",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../../pipes-connectors",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Demo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DemoTests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true
        }
    }
}
