{
  "name": "hanaboso/cm-api",
  "license": "proprietary",
  "type": "project",
  "autoload": {
    "psr-4": {
      "CleverConnectors\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=7.2",
    "hanaboso/acl-bundle": "^1.0",
    "hanaboso/commons-bundle": "^1.0",
    "hanaboso/email-service-bundle": "^1.0",
    "hanaboso/pipes-framework": "^1.0",
    "hanaboso/rabbit-mq-bundle": "^1.0",
    "hanaboso/user-bundle": "^1.0",
    "nelmio/cors-bundle": "^1.5",
    "ocramius/proxy-manager": "^2.2",
    "react/child-process": "^0.5",
    "ruflin/elastica": "^6.0"
  },
  "require-dev": {
    "hanaboso/php-check-utils": "^1.0"
  },
  "config": {
    "sort-packages": true
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../../pf-bundles",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "git",
      "url": "git@gitlab.hanaboso.net:hanaboso/acl-bundle.git"
    },
    {
      "type": "git",
      "url": "git@gitlab.hanaboso.net:hanaboso/email-service-bundle.git"
    },
    {
      "type": "git",
      "url": "git@gitlab.hanaboso.net:hanaboso/commons-bundle.git"
    },
    {
      "type": "git",
      "url": "git@gitlab.hanaboso.net:hanaboso/user-bundle.git"
    },
    {
      "type": "git",
      "url": "git@gitlab.hanaboso.net:hanaboso/rabbit-mq-bundle.git"
    }
  ]
}
