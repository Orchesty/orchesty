{
  "name": "applinth-ui",
  "version": "0.1.0",
  "license": "Elastic-2.0",
  "scripts": {
    "serve": "vue-cli-service serve",
    "start": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "dev": "VUE_APP_BACKEND_URL=http://localhost:8080 VUE_APP_DISABLE_AUTH=true VUE_APP_MSW=true npm run start",
    "lint": "eslint '**/*.{js,ts,vue}'",
    "lint:fix": "eslint --fix '**/*.{js,ts,vue}'",
    "lint:styles": "stylelint '**/*.{css,scss,vue}'",
    "lint:styles:fix": "stylelint --fix '**/*.{css,scss,vue}'",
    "format:check": "prettier --check '**/*.{js,ts,vue,json,yml,mjs,css,scss,md}'",
    "format": "prettier --write '**/*.{js,ts,vue,json,yml,mjs,css,scss,md}'",
    "validate": "run-p -l lint lint:styles format:check"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.12.2",
    "core-js": "^3.45.1",
    "moment": "^2.30.1",
    "pretty-ms": "^9.3.0",
    "validator": "^13.15.15",
    "vee-validate": "^3.4.15",
    "vue": "^2.7.16",
    "vue-i18n": "^8.28.2",
    "vue-router": "^3.6.5",
    "vuetify": "^2.7.2",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/eslint-parser": "^7.28.4",
    "@vue/cli-plugin-babel": "5.0.9",
    "@vue/cli-plugin-eslint": "^5.0.9",
    "@vue/cli-plugin-router": "^5.0.9",
    "@vue/cli-plugin-vuex": "^5.0.9",
    "@vue/cli-service": "^5.0.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-vue": "^8.7.1",
    "jose": "^6.1.0",
    "msw": "^2.11.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.0",
    "prettier": "^2.8.8",
    "sass": "^1.93.2",
    "sass-loader": "^12.6.0",
    "stylelint": "^16.24.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-recommended-scss": "^16.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "vue-cli-plugin-vuetify": "^2.5.8",
    "vue-template-compiler": "^2.7.16",
    "vuetify-loader": "^1.9.2"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
