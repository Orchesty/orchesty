{
  "name": "applinth-ui",
  "version": "0.1.0",
  "license": "Elastic-2.0",
  "scripts": {
    "serve": "vue-cli-service serve",
    "start": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "dev": "VUE_APP_BACKEND_URL=http://localhost:8080 VUE_APP_DISABLE_AUTH=true VUE_APP_MSW=true npm run start",
    "lint": "eslint '**/*.{js,ts,vue}'",
    "lint:fix": "eslint --fix '**/*.{js,ts,vue}'",
    "lint:styles": "stylelint '**/*.{css,scss,vue}'",
    "lint:styles:fix": "stylelint --fix '**/*.{css,scss,vue}'",
    "format:check": "prettier --check '**/*.{js,ts,vue,json,yml,mjs,css,scss,md}'",
    "format": "prettier --write '**/*.{js,ts,vue,json,yml,mjs,css,scss,md}'",
    "validate": "run-p -l lint lint:styles format:check"
  },
  "packageManager": "pnpm@7.21.0",
  "dependencies": {
    "@mdi/font": "^6.9.96",
    "axios": "^1.3.2",
    "core-js": "^3.27.2",
    "moment": "^2.29.4",
    "pretty-ms": "^8.0.0",
    "validator": "^13.9.0",
    "vee-validate": "^3.4.14",
    "vue": "^2.7.14",
    "vue-i18n": "^8.28.2",
    "vue-router": "^3.6.5",
    "vuetify": "^2.6.14",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/eslint-parser": "^7.19.1",
    "@vue/cli-plugin-babel": "~5.0.8",
    "@vue/cli-plugin-eslint": "~5.0.8",
    "@vue/cli-plugin-router": "~5.0.8",
    "@vue/cli-plugin-vuex": "~5.0.8",
    "@vue/cli-service": "~5.0.8",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^8.7.1",
    "jose": "^4.11.4",
    "msw": "^0.47.4",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.21",
    "postcss-html": "^1.5.0",
    "prettier": "^2.8.4",
    "sass": "^1.58.0",
    "sass-loader": "^12.6.0",
    "stylelint": "^14.16.1",
    "stylelint-config-prettier-scss": "^0.0.1",
    "stylelint-config-recommended-scss": "^8.0.0",
    "stylelint-config-recommended-vue": "^1.4.0",
    "stylelint-config-standard-scss": "^6.1.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "vue-cli-plugin-vuetify": "~2.5.8",
    "vue-template-compiler": "^2.7.14",
    "vuetify-loader": "^1.9.2"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
